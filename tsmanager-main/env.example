# Copy to .env and use as-is (everything is pre-set for the new MySQL container)
# cp env.example .env

# Traefik host - your domain or subdomain (e.g. tsmanager.yourdomain.com)
TRAEFIK_HOST=tsmanager.yourdomain.com

# --- NEW MySQL container (use these to access from VM) ---
MYSQL_DATABASE=tsmanager_db
MYSQL_USER=tsmanager_app
MYSQL_PASSWORD=TsManagerApp2025!
MYSQL_ROOT_PASSWORD=TsManagerRoot2025!

# SMTP (Gmail or your provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=TSManager
